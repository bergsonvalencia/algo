{"schema":"algviz/1","title":"Course Schedule (Topological Sort)","topic":"graphs","code":["static bool CanFinish(int numCourses, int[][] prerequisites)","{","    var adj = new List<int>[numCourses];","    for (int i = 0; i < numCourses; i++) adj[i] = new();","    var indeg = new int[numCourses];","    foreach (int[] p in prerequisites) // [course, prereq]","    {","        adj[p[1]].Add(p[0]);  // edge prereq -> course","        indeg[p[0]]++;","    }","    var q = new Queue<int>();","    for (int i = 0; i < numCourses; i++)","        if (indeg[i] == 0) q.Enqueue(i);","    int taken = 0;","    while (q.Count > 0)","    {","        int u = q.Dequeue();","        taken++;","        foreach (int v in adj[u])","            if (--indeg[v] == 0) q.Enqueue(v);","    }","    return taken == numCourses;","}"],"structures":{"g":{"type":"graph","label":"courses (edge: prereq -> course)"},"indeg":{"type":"array1d","label":"indeg[] (unmet prerequisites)"},"q":{"type":"queue","label":"ready queue (in-degree 0)"}},"frames":[{"line":9,"caption":"Build in-degrees from the edges: indeg = [0, 1, 1, 2, 1]. Course 0 has none (ready); the rest are blocked.","note":"A topological order exists iff this directed graph is a DAG (no cycle). Kahn's algorithm finds one by peeling off in-degree-0 vertices. First we count, for each course, how many prerequisites point at it — that in-degree is how many blockers remain before the course becomes takeable.","vars":{"numCourses":5,"indeg":"[0, 1, 1, 2, 1]"},"result":null,"states":{"g":{"type":"graph","directed":true,"nodes":[{"key":"0","value":0,"x":30,"y":12},{"key":"1","value":1,"x":14,"y":46},{"key":"2","value":2,"x":50,"y":46},{"key":"3","value":3,"x":32,"y":78},{"key":"4","value":4,"x":72,"y":90}],"edges":[{"from":"0","to":"1"},{"from":"0","to":"2"},{"from":"1","to":"3"},{"from":"2","to":"3"},{"from":"3","to":"4"}]},"indeg":{"type":"array1d","cells":[{"key":"c0","value":0},{"key":"c1","value":1},{"key":"c2","value":1},{"key":"c3","value":2},{"key":"c4","value":1}],"range":null},"q":{"type":"queue","items":[],"front":0}}},{"line":13,"caption":"Seed the queue with every in-degree-0 course: [0]. These have no prerequisites.","note":"Kahn starts from the courses with NO prerequisites — the in-degree-0 vertices. These are the only ones you can take first, because nothing must come before them. Everything downstream stays blocked until its prerequisites are cleared, which is exactly what the in-degree count tracks.","vars":{"numCourses":5,"indeg":"[0, 1, 1, 2, 1]","queue":"[0]","taken":0},"result":null,"states":{"g":{"type":"graph","directed":true,"nodes":[{"key":"0","value":0,"x":30,"y":12,"highlight":"frontier"},{"key":"1","value":1,"x":14,"y":46},{"key":"2","value":2,"x":50,"y":46},{"key":"3","value":3,"x":32,"y":78},{"key":"4","value":4,"x":72,"y":90}],"edges":[{"from":"0","to":"1"},{"from":"0","to":"2"},{"from":"1","to":"3"},{"from":"2","to":"3"},{"from":"3","to":"4"}]},"indeg":{"type":"array1d","cells":[{"key":"c0","value":0},{"key":"c1","value":1},{"key":"c2","value":1},{"key":"c3","value":2},{"key":"c4","value":1}],"range":null},"q":{"type":"queue","items":[{"key":"q0","value":0,"highlight":"frontier"}],"front":0}}},{"line":17,"caption":"Dequeue 0, take it (taken = 1). Scan the courses it unlocks: [1, 2].","note":"Dequeue a ready course and append it to the order: every prerequisite it had has already been emitted, so taking it now respects all dependencies. Each dequeued course is permanently placed — Kahn never revisits a vertex, which is why the whole run is O(V + E).","vars":{"numCourses":5,"indeg":"[0, 1, 1, 2, 1]","queue":"[0]","taken":1,"order":"[0]"},"result":null,"states":{"g":{"type":"graph","directed":true,"nodes":[{"key":"0","value":0,"x":30,"y":12,"highlight":"current"},{"key":"1","value":1,"x":14,"y":46},{"key":"2","value":2,"x":50,"y":46},{"key":"3","value":3,"x":32,"y":78},{"key":"4","value":4,"x":72,"y":90}],"edges":[{"from":"0","to":"1","highlight":"path"},{"from":"0","to":"2","highlig